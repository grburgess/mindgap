#!/bin/sh
# Run mindgap from a source checkout without installing.
# Resolve repo root from this script's own location (follows the install symlink).
SELF=$0
while [ -L "$SELF" ]; do SELF=$(readlink "$SELF"); done
REPO=$(CDPATH= cd -- "$(dirname -- "$SELF")/.." && pwd)
PYTHONPATH="$REPO${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m mindgap "$@"
